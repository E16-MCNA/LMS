{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "db:migrate": "tsx scripts/dbMigrate.ts",
    "db:drift": "tsx scripts/dbDriftCheck.ts",
    "db:seed": "tsx scripts/dbSeed.ts",
    "test:e2e": "tsx scripts/e2eAcademicFlow.ts",
    "test:regression": "tsx scripts/e2eRegressionFlow.ts",
    "smoke:deploy": "tsx scripts/smokeDeploy.ts",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.100.14",
    "@types/multer": "^2.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
