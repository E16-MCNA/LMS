# Required
NODE_ENV=production
PORT=3000
JWT_SECRET=
DATABASE_URL=
REDIS_URL=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Google Gemini
GEMINI_API_KEY=

# Optional
DISABLE_RATE_LIMIT=

# Google Workspace Email Provisioning
SCHOOL_EMAIL_DOMAIN=mcna.edu.vn
GOOGLE_ADMIN_EMAIL=admin@mcna.edu.vn
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
LMS_LOGIN_URL=https://lms.mcna.edu.vn

# SMTP (dùng OAuth2 qua Gmail/Google Workspace)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=noreply@mcna.edu.vn
